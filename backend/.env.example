# Configurações do Workana
WORKANA_EMAIL=seu_email@exemplo.com
WORKANA_PASSWORD=sua_senha

# Configurações de segurança
SECRET_KEY=sua_chave_secreta_aqui_mude_em_producao
ENCRYPTION_KEY=chave_para_criptografar_credenciais

# Configurações da API
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# Configurações de automação
HEADLESS=true
SLOW_MO=100
MAX_PROPOSALS_PER_DAY=10
DELAY_BETWEEN_ACTIONS_MS=2000

# Banco local para desenvolvimento. No Render, use a URL do session pooler
# Supavisor na porta 5432, obtida em Dashboard > Connect.
DATABASE_URL=sqlite+aiosqlite:///./workana.db
# DATABASE_URL=postgresql+asyncpg://postgres.omfrvmbsazgfwhapsaur:[SUA_SENHA]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres

# Supabase Auth e Conexão (Para validação JWT no backend)
SUPABASE_URL=https://omfrvmbsazgfwhapsaur.supabase.co
SUPABASE_JWKS_URL=https://omfrvmbsazgfwhapsaur.supabase.co/auth/v1/.well-known/jwks.json
