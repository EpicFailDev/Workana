# Configurações do Workana
WORKANA_EMAIL=seu_email@exemplo.com
WORKANA_PASSWORD=sua_senha

# Configurações de segurança
SECRET_KEY=sua_chave_secreta_aqui_mude_em_producao
ENCRYPTION_KEY=chave_de_criptografia_simetrica_de_32_bytes_exatamente

# Configurações da API
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# Configurações de automação
HEADLESS=true
SLOW_MO=100
MAX_PROPOSALS_PER_DAY=10
DELAY_BETWEEN_ACTIONS_MS=2000

# Banco de dados PostgreSQL (SQLite descontinuado)
DATABASE_URL=postgresql+asyncpg://postgres.cztwxtsuewwacjcgajjz:[SUA_SENHA_AQUI]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres

# Supabase Auth e Conexão (Para validação JWT no backend)
SUPABASE_URL=https://cztwxtsuewwacjcgajjz.supabase.co
SUPABASE_JWKS_URL=https://cztwxtsuewwacjcgajjz.supabase.co/auth/v1/.well-known/jwks.json
CATALOG_DEFAULT_KEYWORDS=desenvolvimento software
CATALOG_DEFAULT_CATEGORY=
CATALOG_MAX_SEARCHES_PER_CYCLE=20
CATALOG_MAX_PROJECTS_PER_CYCLE=500
CATALOG_PAGES_PER_SEARCH=3
CATALOG_CLOSE_AFTER_CYCLES=3
CATALOG_SEARCH_RETRIES=2
