# =========================================================================
# CONFIGURAÇÕES PRIVADAS (Apenas para o Backend/API/Worker - Segredo Absoluto)
# =========================================================================
# URL de conexão direta IPv6 ou Supavisor Session Mode (porta 5432) do Supabase
DATABASE_URL=postgresql+asyncpg://postgres.omfrvmbsazgfwhapsaur:[SUA_SENHA_AQUI]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres

# Conexão administrativa (reservada exclusivamente para migrations)
MIGRATIONS_DATABASE_URL=postgresql://postgres.omfrvmbsazgfwhapsaur:[SUA_SENHA_AQUI]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres

# URL de JWKS do Supabase (para validação local de JWT)
SUPABASE_JWKS_URL=https://omfrvmbsazgfwhapsaur.supabase.co/auth/v1/.well-known/jwks.json

# Chaves de segurança da aplicação (devem ser seguras e alteradas em produção com debug=false)
SECRET_KEY=sua_chave_secreta_jwt_para_producao_super_segura
ENCRYPTION_KEY=chave_de_criptografia_simetrica_de_32_bytes_exatamente

# Modo de depuração (false em produção)
DEBUG=true

# Credenciais padrão para automação do Workana (criptografadas e salvas no banco)
WORKANA_EMAIL=seu_email@exemplo.com
WORKANA_PASSWORD=sua_senha_do_workana

# Chaves de APIs Externas
GEMINI_API_KEY=sua_chave_do_gemini_para_gerar_propostas_por_ia

# Parâmetros de Automação
HEADLESS=true
PROXY_URL=http://usuario:senha@host_do_proxy:porta
CAPTCHA_PROVIDER=2captcha
CAPTCHA_API_KEY=sua_chave_do_servico_de_captcha

